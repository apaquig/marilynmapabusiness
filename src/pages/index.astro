<style>
/* ══════════════════════════════════════
   NAVBAR STICKY GLASSMORPHISM
══════════════════════════════════════ */
nav {
  transition: background 0.4s ease, box-shadow 0.4s ease !important;
}
nav.scrolled {
  background: rgba(8, 8, 8, 0.93) !important;
  backdrop-filter: blur(18px) !important;
  -webkit-backdrop-filter: blur(18px) !important;
  box-shadow: 0 2px 40px rgba(0,0,0,0.55) !important;
}

/* ══════════════════════════════════════
   HERO ANIMATIONS
══════════════════════════════════════ */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(32px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes slideRight {
  from { opacity: 0; transform: translateX(50px); }
  to   { opacity: 1; transform: translateX(0); }
}

.hero-tag      { animation: fadeUp 0.65s ease both; animation-delay: 0.1s; }
.hero-text h1  { animation: fadeUp 0.65s ease both; animation-delay: 0.25s; }
.hero-subtitle { animation: fadeUp 0.65s ease both; animation-delay: 0.4s; }
.hero-badges   { animation: fadeUp 0.65s ease both; animation-delay: 0.55s; }
.hero-buttons  { animation: fadeUp 0.65s ease both; animation-delay: 0.7s; }
.hero-social-anim { animation: fadeUp 0.65s ease both; animation-delay: 0.85s; }
.hero-image-wrap  { animation: slideRight 0.85s ease both; animation-delay: 0.2s; }

/* ══════════════════════════════════════
   SCROLL REVEAL
══════════════════════════════════════ */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.65s ease, transform 0.65s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }
.rv1 { transition-delay: 0.08s; }
.rv2 { transition-delay: 0.18s; }
.rv3 { transition-delay: 0.28s; }
.rv4 { transition-delay: 0.38s; }

/* ══════════════════════════════════════
   SERVICE CARD HOVER UPGRADE
══════════════════════════════════════ */
.service-card {
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease !important;
  border: 1px solid transparent !important;
  position: relative;
  overflow: hidden;
}
.service-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(220,38,38,0.07), transparent 60%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}
.service-card:hover {
  transform: translateY(-7px) !important;
  box-shadow: 0 22px 52px rgba(0,0,0,0.38) !important;
  border-color: rgba(220,38,38,0.28) !important;
}
.service-card:hover::after { opacity: 1; }
.service-icon {
  display: inline-block;
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.service-card:hover .service-icon { transform: scale(1.2) rotate(-5deg); }

/* ══════════════════════════════════════
   ABOUT FEATURE CARDS
══════════════════════════════════════ */
.about-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 11px;
  margin: 22px 0 28px;
}
.feature-card {
  display: flex;
  align-items: flex-start;
  gap: 11px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 13px 15px;
  transition: background 0.25s, border-color 0.25s, transform 0.25s;
  cursor: default;
}
.feature-card:hover {
  background: rgba(220,38,38,0.09);
  border-color: rgba(220,38,38,0.28);
  transform: translateY(-2px);
}
.feature-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 1px; }
.feature-text {
  font-size: 0.8rem;
  line-height: 1.45;
  color: rgba(255,255,255,0.7);
  font-family: 'Lato', sans-serif;
}
.feature-text strong {
  display: block;
  font-size: 0.86rem;
  color: #fff;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  margin-bottom: 1px;
}
@media (max-width: 520px) { .about-features { grid-template-columns: 1fr; } }

/* ══════════════════════════════════════
   TESTIMONIALS SLIDER & GOOGLE CARDS
══════════════════════════════════════ */
/* Estilos de testimonios trasladados a GoogleReviews.astro */


/* ══════════════════════════════════════
   FORM SUCCESS STATE
══════════════════════════════════════ */
.form-success {
  display: none;
  text-align: center;
  padding: 52px 28px;
  animation: fadeIn 0.5s ease;
}
.form-success.show { display: block; }
.success-icon { font-size: 3.5rem; margin-bottom: 16px; }
.success-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: 1.4rem;
  color: #fff;
  margin-bottom: 10px;
}
.success-msg {
  color: rgba(255,255,255,0.55);
  font-size: 0.93rem;
  line-height: 1.65;
  margin-bottom: 26px;
}
.success-wa {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #25D366;
  color: #fff;
  padding: 13px 26px;
  border-radius: 50px;
  text-decoration: none;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 0.9rem;
  transition: transform 0.22s, box-shadow 0.22s;
}
.success-wa:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,211,102,0.38); }

/* Input focus states */
.contact-form input:focus,
.contact-form select:focus,
.contact-form textarea:focus {
  outline: none;
  border-color: rgba(220,38,38,0.65) !important;
  box-shadow: 0 0 0 3px rgba(220,38,38,0.13) !important;
  transition: border-color 0.2s, box-shadow 0.2s;
}

/* ══════════════════════════════════════
   SOCIAL MEDIA BUTTONS
══════════════════════════════════════ */
.social-links { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
.social-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 9px 17px; border-radius: 50px;
  font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.81rem;
  text-decoration: none; white-space: nowrap;
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}
.social-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 22px rgba(0,0,0,0.32); filter: brightness(1.1); }
.social-btn svg { width: 17px; height: 17px; flex-shrink: 0; }

.social-btn-icon {
  display: inline-flex; align-items: center; justify-content: center;
  width: 44px; height: 44px; border-radius: 50%; text-decoration: none;
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}
.social-btn-icon:hover { transform: translateY(-3px) scale(1.08); box-shadow: 0 8px 24px rgba(0,0,0,0.4); filter: brightness(1.1); }
.social-btn-icon svg { width: 20px; height: 20px; }

.social-facebook  { background: #1877F2; color: #fff; }
.social-instagram { background: linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888); color:#fff; }
.social-tiktok    { background: #010101; color:#fff; border:1px solid #2a2a2a; }
.social-youtube   { background: #FF0000; color:#fff; }

.contact-social-area { margin-top:30px; padding-top:22px; border-top:1px solid rgba(255,255,255,0.09); }
.contact-social-area p {
  font-size: 0.78rem; color: rgba(255,255,255,0.42); margin-bottom:13px;
  font-family: 'Montserrat', sans-serif; text-transform: uppercase; letter-spacing: 1.5px;
}
.footer-social { display:flex; gap:12px; justify-content:center; margin:18px 0; }

/* ══════════════════════════════════════
   HAMBURGER ANIMATED
══════════════════════════════════════ */
.hamburger span {
  display: block; width:24px; height:2px; background:#fff;
  margin:5px 0; border-radius:2px;
  transition: transform 0.32s ease, opacity 0.32s ease;
  transform-origin: center;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity:0; transform:scaleX(0); }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
</style>
</head>
