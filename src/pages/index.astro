<script define:vars={{ cities }}>
  // Wait for Leaflet to be fully loaded
  const initMap = () => {
    const mapEl = document.getElementById('nj-map');
    if (!mapEl) return;

    let mapInitialized = false;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !mapInitialized) {
          mapInitialized = true;
          initializeMap();
          observer.disconnect();
        }
      });
    }, { rootMargin: '200px' });

    observer.observe(mapEl);

    function initializeMap() {
      if (typeof L === 'undefined') {
        console.error('Leaflet library (L) is not defined. Map tiles cannot be loaded.');
        return;
      }
      // 1. Initialize Leaflet Map centered in New Jersey
      const map = L.map('nj-map', {
        center: [40.40, -74.40],
        zoom: 8.5,
        scrollWheelZoom: false,
        zoomControl: true
      });

      // 2. Load CartoDB Dark Matter tile layer
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 20
      }).addTo(map);

      // 3. Custom Markers and Synchronization
      const markers = {};
      const cityItems = document.querySelectorAll('.city-item');

      // Helper to clear active classes
      function clearActive() {
        cityItems.forEach(item => {
          item.classList.remove('active');
          item.classList.remove('selected-active');
        });
        Object.values(markers).forEach(m => {
          const iconElement = m.getElement();
          if (iconElement) {
            iconElement.classList.remove('active');
          }
        });
      }

      // Helper to highlight a city by slug
      function highlightCity(slug, scroll = false) {
        cityItems.forEach(item => {
          if (item.getAttribute('data-slug') === slug) {
            item.classList.add('active');
            if (scroll) {
              item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
          } else {
            item.classList.remove('active');
          }
        });
        
        Object.entries(markers).forEach(([s, m]) => {
          const iconEl = m.getElement();
          if (iconEl) {
            if (s === slug) {
              iconEl.classList.add('active');
            } else {
              iconEl.classList.remove('active');
            }
          }
        });
      }

      // Create markers for each city
      cities.forEach(city => {
        // Create customized speech bubble popup icon as L.divIcon
        const customIcon = L.divIcon({
          className: 'custom-marker',
          html: `
            <div class="marker-pin"></div>
            <div class="marker-label">${city.name}</div>
          `,
          iconSize: [24, 24],
          iconAnchor: [12, 12]
        });

        const marker = L.marker([city.lat, city.lng], { icon: customIcon }).addTo(map);
        markers[city.slug] = marker;

        // Event listeners on Marker
        marker.on('mouseover', () => {
          highlightCity(city.slug, true);
        });

        marker.on('mouseout', () => {
          const sidebarItem = document.querySelector(`.city-item[data-slug="${city.slug}"]`);
          if (sidebarItem && !sidebarItem.classList.contains('selected-active')) {
            clearActive();
          }
        });

        marker.on('click', () => {
          highlightCity(city.slug, true);
          const sidebarItem = document.querySelector(`.city-item[data-slug="${city.slug}"]`);
          if (sidebarItem) {
            sidebarItem.classList.add('selected-active');
          }
          
          // Navigation after a brief highlight transition
          setTimeout(() => {
            window.location.href = `/service-areas/${city.slug}/`;
          }, 300);
        });
      });

      // Event listeners on Sidebar Items
      cityItems.forEach(item => {
        const slug = item.getAttribute('data-slug');

        item.addEventListener('mouseenter', () => {
          highlightCity(slug, false);
        });

        item.addEventListener('mouseleave', () => {
          if (!item.classList.contains('selected-active')) {
            clearActive();
          }
        });

        item.addEventListener('click', (e) => {
          e.preventDefault();
          highlightCity(slug, false);
          item.classList.add('selected-active');

          setTimeout(() => {
            window.location.href = `/service-areas/${slug}/`;
          }, 300);
        });
      });

      // 4. Reactive Search Filter
      const searchInput = document.getElementById('citySearch');
      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          const term = e.target.value.toLowerCase().trim();
          
          cityItems.forEach(item => {
            const name = item.getAttribute('data-name').toLowerCase();
            const county = item.getAttribute('data-county').toLowerCase();
            const slug = item.getAttribute('data-slug');

            if (name.includes(term) || county.includes(term)) {
              item.style.display = 'flex';
              if (markers[slug] && !map.hasLayer(markers[slug])) {
                map.addLayer(markers[slug]);
              }
            } else {
              item.style.display = 'none';
              if (markers[slug] && map.hasLayer(markers[slug])) {
                map.removeLayer(markers[slug]);
              }
            }
          });
        });
      }
    };
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>

<script src="/js/script.js" is:inline></script>
</body>
</html>