---
// src/pages/servicios/[service].astro
// Genera páginas pilares (Hub) para cada servicio general en New Jersey
// Ejemplo: /servicios/notaria/ · /servicios/itin/ · /servicios/taxes/

import { cities } from "../../data/cities";
import { services } from "../../data/services";
import '../../styles/global.css';
import WhatsAppWidget from "../../components/WhatsAppWidget.astro";

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const PHONE      = "(862) 622-8339";
const PHONE_HREF = "+18626228339";
const WEBSITE    = "https://marilynmapabusiness.com";

const title       = `${service.name} en New Jersey | MAPA Business`;
const description = `Servicio profesional de ${service.name} en New Jersey. Cobertura en Newark, Elizabeth, Paterson, Jersey City y más. Marilyn Paladinez: ${PHONE}.`;
const canonical   = `${WEBSITE}/servicios/${service.slug}/`;

// Schema JSON-LD para el servicio general
const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${service.name} en New Jersey`,
  description: description,
  url: canonical,
  provider: {
    "@type": service.schemaType,
    name: "MAPA Business & Financial Services LLC",
    telephone: `+1${PHONE_HREF}`,
    image: `${WEBSITE}/marilin2.webp`,
    priceRange: "$$",
    address: {
      "@type": "PostalAddress",
      streetAddress: "20 Bloomfield Pl",
      addressLocality: "Newark",
      addressRegion: "NJ",
      postalCode: "07104",
      addressCountry: "US",
    }
  },
  areaServed: [
    { "@type": "State", name: "New Jersey", addressRegion: "NJ" },
    ...cities.map((city) => ({ "@type": "City", name: city.name, addressRegion: "NJ" }))
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: service.name,
    itemListElement: cities.map((city) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: `${service.name} en ${city.name}, NJ`,
        url: `${WEBSITE}/service-areas/${city.slug}/${service.slug}/`
      }
    }))
  }
};

// FAQ Schema (Reemplazando {city} con "New Jersey" para el contexto estatal)
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: service.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question.replace("{city}", "New Jersey"),
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio",     item: WEBSITE },
    { "@type": "ListItem", position: 2, name: "Servicios", item: `${WEBSITE}/#servicios` },
    { "@type": "ListItem", position: 3, name: service.name, item: canonical },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={`${WEBSITE}/marilin2.webp`} />
    <meta property="og:locale"      content="es_US" />

    <!-- Schemas -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <!-- i18n Translation Engine -->
    <script src="/js/i18n.js" is:inline></script>

    <style>
      :root { --red: #cc0000; --black: #0a0a0a; --white: #ffffff; }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { font-family: 'Lato', sans-serif; background: var(--black); color: var(--white); }

      /* NAV */
      nav#mainNav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(10,10,10,0.97); border-bottom: 2px solid var(--red); display: flex; align-items: center; justify-content: space-between; padding: 0 40px; height: 70px; }
      .nav-logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.4rem; color: #fff; letter-spacing: 4px; text-decoration: none; }
      .nav-logo span { color: var(--red); }
      .nav-cta { background: var(--red); color: #fff; padding: 10px 20px; border-radius: 4px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.8rem; text-decoration: none; text-transform: uppercase; letter-spacing: 1px; }

      /* BREADCRUMB */
      .breadcrumb { max-width: 1100px; margin: 70px auto 0; padding: 16px 40px 0; display: flex; gap: 8px; font-size: 0.8rem; color: rgba(255,255,255,0.4); flex-wrap: wrap; }
      .breadcrumb a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
      .breadcrumb a:hover { color: var(--red); }
      .breadcrumb span { color: rgba(255,255,255,0.6); }

      /* HERO */
      .page-hero { max-width: 1100px; margin: 0 auto; padding: 40px 40px 60px; position: relative; }
      .page-hero::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 50% 80% at 80% 50%, rgba(204,0,0,0.1) 0%, transparent 70%);
        pointer-events: none;
      }
      .page-tag { display: inline-block; background: rgba(204,0,0,0.15); border: 1px solid rgba(204,0,0,0.4); color: var(--red); font-family: 'Montserrat', sans-serif; font-size: 0.65rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; padding: 4px 12px; border-radius: 2px; margin-bottom: 16px; position: relative; z-index: 2; }
      .page-icon { font-size: 3rem; margin-bottom: 12px; display: block; position: relative; z-index: 2; }
      .page-hero h1 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1.1; margin-bottom: 20px; position: relative; z-index: 2; }
      .page-hero h1 span { color: var(--red); }
      .page-intro { font-size: 1.05rem; color: rgba(255,255,255,0.7); line-height: 1.7; max-width: 700px; margin-bottom: 32px; position: relative; z-index: 2; }
      .btn-group { display: flex; gap: 14px; flex-wrap: wrap; position: relative; z-index: 2; }
      .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 4px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; transition: all 0.25s; }
      .btn-red { background: var(--red); color: #fff; }
      .btn-red:hover { background: #ff2222; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(204,0,0,0.5); }
      .btn-wa { background: #25d366; color: #fff; }
      .btn-wa:hover { background: #1da851; transform: translateY(-2px); }

      /* CITIES GRID - SPOKE LINKS */
      .cities-section { background: #0f0f0f; padding: 60px 40px; border-top: 1px solid rgba(255,255,255,0.05); }
      .cities-inner { max-width: 1100px; margin: 0 auto; }
      .section-label { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.6rem; margin-bottom: 8px; }
      .section-label span { color: var(--red); }
      .section-desc { color: rgba(255,255,255,0.5); font-size: 0.95rem; margin-bottom: 32px; line-height: 1.65; }
      
      .cities-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
      .city-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 6px;
        padding: 20px;
        text-decoration: none;
        color: #fff;
        transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }
      .city-card:hover {
        transform: translateY(-4px);
        border-color: rgba(204,0,0,0.35);
        box-shadow: 0 12px 30px rgba(0,0,0,0.4);
      }
      .city-name { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 1rem; margin-bottom: 4px; }
      .city-county { font-size: 0.78rem; color: rgba(255,255,255,0.4); margin-bottom: 12px; }
      .city-link { color: var(--red); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-top: auto; }

      /* FAQ */
      .faq-section { max-width: 1100px; margin: 0 auto; padding: 60px 40px; }
      .faq-section h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.6rem; margin-bottom: 30px; }
      .faq-section h2 span { color: var(--red); }
      .faq-item { border-bottom: 1px solid rgba(255,255,255,0.07); padding: 20px 0; }
      .faq-item dt { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.95rem; color: #fff; margin-bottom: 10px; }
      .faq-item dd { font-size: 0.9rem; color: rgba(255,255,255,0.6); line-height: 1.7; }

      /* CTA */
      .cta-section { background: var(--red); padding: 60px 40px; text-align: center; }
      .cta-section h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.8rem; margin-bottom: 12px; }
      .cta-section p { color: rgba(255,255,255,0.85); margin-bottom: 28px; font-size: 1rem; }
      .btn-white { background: #fff; color: var(--red); font-family: 'Montserrat', sans-serif; font-weight: 700; padding: 14px 32px; border-radius: 4px; text-decoration: none; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; transition: transform 0.2s; display: inline-block; }
      .btn-white:hover { transform: translateY(-2px); }

      /* FOOTER */
      footer { background: #050505; border-top: 2px solid var(--red); padding: 30px 40px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
      .footer-logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.2rem; color: #fff; letter-spacing: 3px; }
      .footer-logo span { color: var(--red); }
      footer p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
      footer a { color: rgba(255,255,255,0.4); text-decoration: none; font-size: 0.8rem; }
      footer a:hover { color: var(--red); }

      /* WA FLOAT */
      .wa-float { position: fixed; bottom: 28px; right: 28px; z-index: 999; background: #25d366; width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; box-shadow: 0 6px 25px rgba(37,211,102,0.5); animation: pulse-wa 2.5s infinite; }
      @keyframes pulse-wa { 0%,100%{box-shadow:0 6px 25px rgba(37,211,102,.5);}50%{box-shadow:0 6px 35px rgba(37,211,102,.8),0 0 0 12px rgba(37,211,102,.12);} }
      .wa-float svg { width: 28px; height: 28px; }

      @media (max-width: 700px) {
        nav#mainNav { padding: 0 20px; }
        .breadcrumb, .page-hero, .faq-section { padding-left: 20px; padding-right: 20px; }
        .cities-section, .cta-section { padding: 40px 20px; }
        footer { padding: 24px 20px; flex-direction: column; text-align: center; }
      }
    </style>
  </head>

  <body>

    <!-- WhatsApp flotante -->
    <WhatsAppWidget phoneHref={PHONE_HREF} text={`Hola Marilyn, me interesa el servicio de ${service.name} en New Jersey.`} />

    <!-- NAVBAR -->
    <nav id="mainNav">
      <div class="nav-logo">M<span>A</span>PA</div>
      <ul class="nav-links" id="navLinks">
        <li><a href="/#hero" data-i18n="nav.home">Inicio</a></li>
        <li><a href="/#servicios" data-i18n="nav.services">Servicios</a></li>
        <li><a href="/#nosotros" data-i18n="nav.about">Nosotros</a></li>
        <li><a href="/#proceso" data-i18n="nav.process">Proceso</a></li>
        <li><a href="/#testimonios" data-i18n="nav.testimonials">Testimonios</a></li>
        <li><a href="/#contacto" data-i18n="nav.contact">Contacto</a></li>
        <li><a href="/#areas-de-servicio" data-i18n="nav.coverage">Áreas de Servicio</a></li>
        <li><a href="/#ubicacion" data-i18n="nav.location">Ubicación</a></li>
        <li><a href="/blog/" data-i18n="nav.blog">Blog</a></li>
        <li><a href={`tel:${PHONE_HREF}`} class="nav-cta" data-i18n="nav.cta">📞 Cita</a></li>
        <li class="lang-selector-li">
          <div class="lang-selector">
            <button class="lang-btn active" data-lang="es" onclick="window.i18n.changeLanguage('es')" aria-label="Cambiar a Español" aria-pressed="true">ES</button>
            <span class="lang-divider">|</span>
            <button class="lang-btn" data-lang="en" onclick="window.i18n.changeLanguage('en')" aria-label="Switch to English" aria-pressed="false">EN</button>
          </div>
        </li>
      </ul>
      <div class="hamburger" id="hamburger" onclick="toggleMenu()">
        <span></span><span></span><span></span>
      </div>
    </nav>

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Ruta de navegación">
      <a href="/" data-i18n="nav.home">Inicio</a>
      <span>›</span>
      <a href="/#servicios" data-i18n="nav.services">Servicios</a>
      <span>›</span>
      <span data-i18n={`services.${service.slug}.title`}>{service.name}</span>
    </nav>

    <!-- Hero -->
    <div class="page-hero">
      <div class="page-tag" data-i18n="hero.tag_business">MAPA Business & Financial Services LLC</div>
      <div class="page-icon">{service.icon}</div>
      <h1>
        <span data-i18n="services.service_of">Servicio de</span> <span data-i18n={`services.${service.slug}.title`}>{service.name}</span> <span data-i18n="services.in_nj">en New Jersey</span>
      </h1>
      <p class="page-intro" data-i18n={`services.${service.slug}.desc`}>
        Ofrecemos asesoría profesional en español para {service.name} en todo el estado de New Jersey. 
        Contamos con un equipo experimentado y oficinas convenientes para brindarte la mejor atención local.
      </p>
      <div class="btn-group">
        <a href={`tel:${PHONE_HREF}`} class="btn btn-red"><span data-i18n="contact.btn_call">📞 Llamar:</span> {PHONE}</a>
        <a href={`https://wa.me/${PHONE_HREF}?text=Hola%20Marilyn%2C%20necesito%20${encodeURIComponent(service.name)}.`} target="_blank" class="btn btn-wa" data-i18n="hero.btn_whatsapp">💬 WhatsApp</a>
      </div>
    </div>

    <!-- Cobertura de ciudades (Spoke Links) -->
    <div class="cities-section">
      <div class="cities-inner">
        <h2 class="section-label">
          <span data-i18n="services.cities_where">Ciudades donde ofrecemos</span> <span data-i18n={`services.${service.slug}.title`}>{service.name}</span>
        </h2>
        <p class="section-desc" data-i18n="services.cities_desc">
          Selecciona tu ciudad en New Jersey para ver tarifas, oficinas locales y requisitos específicos de atención en tu localidad:
        </p>
        <div class="cities-grid">
          {cities.map((city) => (
            <a href={`/service-areas/${city.slug}/${service.slug}/`} class="city-card">
              <div>
                <div class="city-name">{city.name}</div>
                <div class="city-county">{city.county}</div>
              </div>
              <span class="city-link" data-i18n="services.local_attention">Atención local →</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <section class="faq-section">
      <h2><span data-i18n="services.faq_title_prefix">Preguntas frecuentes sobre</span> <span data-i18n={`services.${service.slug}.title`}>{service.name}</span></h2>
      <dl>
        {service.faqs.map((faq, idx) => (
          <div class="faq-item">
            <dt data-i18n={`services.${service.slug}.faqs.${idx}.q`}>{faq.question.replace("{city}", "New Jersey")}</dt>
            <dd data-i18n={`services.${service.slug}.faqs.${idx}.a`}>{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- CTA final -->
    <div class="cta-section">
      <h2>
        <span data-i18n="services.cta_doubts_prefix">¿Tienes dudas sobre</span> <span data-i18n={`services.${service.slug}.title`}>{service.name}</span>?
      </h2>
      <p data-i18n="services.cta_doubts_desc">Contáctanos hoy para una consulta inicial sin costo. Resolvemos todos tus trámites en tu propio idioma.</p>
      <a href={`tel:${PHONE_HREF}`} class="btn-white">📞 {PHONE}</a>
    </div>

    <!-- Footer -->
    <footer>
      <div class="footer-logo">M<span>A</span>PA</div>
      <p>© {new Date().getFullYear()} <span data-i18n="footer.desc">MAPA Business & Financial Services LLC</span> · Newark, NJ</p>
      <a href="/" data-i18n="city.back_home">← Volver al inicio</a>
    </footer>

    <script>
      window.currentCity = "New Jersey";
    </script>

    <script src="/js/script.js" is:inline></script>
  </body>
</html>
