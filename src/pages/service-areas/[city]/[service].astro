---
// src/pages/[city]/[service].astro
// Genera páginas locales para cada ciudad+servicio
// Ejemplo: /elizabeth/notaria/ · /paterson/taxes/ · /jersey-city/itin/

import { cities } from "../../../data/cities";
import { services } from "../../../data/services";
import '../../../styles/global.css';
import WhatsAppWidget from "../../../components/WhatsAppWidget.astro";

export async function getStaticPaths() {
  return cities.flatMap((city) =>
    services.map((service) => ({
      params: { city: city.slug, service: service.slug },
      props: { city, service },
    }))
  );
}

const { city, service } = Astro.props;

const PHONE      = "(862) 622-8339";
const PHONE_HREF = "+18626228339";
const WEBSITE    = "https://marilynmapabusiness.com";

const title       = service.metaTitle(city.name);
const description = service.metaDescription(city.name);
const canonical   = `${WEBSITE}/service-areas/${city.slug}/${service.slug}/`;

// Schema JSON-LD
const schema = {
  "@context": "https://schema.org",
  "@type": service.schemaType,
  name: "MAPA Business & Financial Services LLC",
  description: description,
  url: canonical,
  telephone: `+1${PHONE_HREF}`,
  image: `${WEBSITE}/marilin2.webp`,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "20 Bloomfield Pl",
    addressLocality: "Newark",
    addressRegion: "NJ",
    postalCode: "07104",
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: city.lat,
    longitude: city.lng,
  },
  areaServed: [
    { "@type": "City", name: city.name, addressRegion: "NJ" },
    ...city.nearbyAreas.map((area) => ({ "@type": "City", name: area })),
  ],
  sameAs: [
    `https://www.wikidata.org/wiki/${city.wikidataId}`
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: service.name,
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: `${service.name} en ${city.name}, NJ`,
          description: service.intro(city.name),
        },
      },
    ],
  },
};

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: service.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question.replace("{city}", city.name),
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio",     item: WEBSITE },
    { "@type": "ListItem", position: 2, name: city.name,    item: `${WEBSITE}/service-areas/${city.slug}/` },
    { "@type": "ListItem", position: 3, name: service.name, item: canonical },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={`${WEBSITE}/marilin2.webp`} />
    <meta property="og:locale"      content="es_US" />

    <!-- Schemas -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <!-- i18n Translation Engine -->
    <script src="/js/i18n.js" is:inline></script>

    <style>
      :root { --red: #cc0000; --black: #0a0a0a; --white: #ffffff; }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { font-family: 'Lato', sans-serif; background: var(--black); color: var(--white); }

      /* NAV */
      nav#mainNav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(10,10,10,0.97); border-bottom: 2px solid var(--red); display: flex; align-items: center; justify-content: space-between; padding: 0 40px; height: 70px; }
      .nav-logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.4rem; color: #fff; letter-spacing: 4px; text-decoration: none; }
      .nav-logo span { color: var(--red); }
      .nav-cta { background: var(--red); color: #fff; padding: 10px 20px; border-radius: 4px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.8rem; text-decoration: none; text-transform: uppercase; letter-spacing: 1px; }

      /* BREADCRUMB */
      .breadcrumb { max-width: 1100px; margin: 70px auto 0; padding: 16px 40px 0; display: flex; gap: 8px; font-size: 0.8rem; color: rgba(255,255,255,0.4); flex-wrap: wrap; }
      .breadcrumb a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
      .breadcrumb a:hover { color: var(--red); }
      .breadcrumb span { color: rgba(255,255,255,0.6); }

      /* HERO */
      .page-hero { max-width: 1100px; margin: 0 auto; padding: 40px 40px 60px; }
      .page-tag { display: inline-block; background: rgba(204,0,0,0.15); border: 1px solid rgba(204,0,0,0.4); color: var(--red); font-family: 'Montserrat', sans-serif; font-size: 0.65rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; padding: 4px 12px; border-radius: 2px; margin-bottom: 16px; }
      .page-icon { font-size: 3rem; margin-bottom: 12px; display: block; }
      .page-hero h1 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1.1; margin-bottom: 20px; }
      .page-hero h1 span { color: var(--red); }
      .page-intro { font-size: 1.05rem; color: rgba(255,255,255,0.7); line-height: 1.7; max-width: 700px; margin-bottom: 20px; }
      .hub-link-wrapper { margin-bottom: 32px; }
      .hub-link { color: rgba(255,255,255,0.55); font-size: 0.88rem; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: color 0.2s; }
      .hub-link:hover { color: var(--red); }
      .btn-group { display: flex; gap: 14px; flex-wrap: wrap; }
      .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 4px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; transition: all 0.25s; }
      .btn-red { background: var(--red); color: #fff; }
      .btn-red:hover { background: #ff2222; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(204,0,0,0.5); }
      .btn-wa { background: #25d366; color: #fff; }
      .btn-wa:hover { background: #1da851; transform: translateY(-2px); }

      /* AREAS */
      .areas-section { background: #0f0f0f; padding: 60px 40px; border-top: 1px solid rgba(255,255,255,0.05); }
      .areas-inner { max-width: 1100px; margin: 0 auto; }
      .section-label { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.4rem; margin-bottom: 20px; }
      .section-label span { color: var(--red); }
      .areas-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 20px; }
      .area-pill { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 50px; padding: 8px 18px; font-size: 0.85rem; color: rgba(255,255,255,0.7); }

      /* FAQ */
      .faq-section { max-width: 1100px; margin: 0 auto; padding: 60px 40px; }
      .faq-section h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.6rem; margin-bottom: 30px; }
      .faq-section h2 span { color: var(--red); }
      .faq-item { border-bottom: 1px solid rgba(255,255,255,0.07); padding: 20px 0; }
      .faq-item dt { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.95rem; color: #fff; margin-bottom: 10px; }
      .faq-item dd { font-size: 0.9rem; color: rgba(255,255,255,0.6); line-height: 1.7; }

      /* CTA */
      .cta-section { background: var(--red); padding: 60px 40px; text-align: center; }
      .cta-section h2 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.8rem; margin-bottom: 12px; }
      .cta-section p { color: rgba(255,255,255,0.85); margin-bottom: 28px; font-size: 1rem; }
      .btn-white { background: #fff; color: var(--red); font-family: 'Montserrat', sans-serif; font-weight: 700; padding: 14px 32px; border-radius: 4px; text-decoration: none; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; transition: transform 0.2s; display: inline-block; }
      .btn-white:hover { transform: translateY(-2px); }

      /* FOOTER */
      footer { background: #050505; border-top: 2px solid var(--red); padding: 30px 40px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
      .footer-logo { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.2rem; color: #fff; letter-spacing: 3px; }
      .footer-logo span { color: var(--red); }
      footer p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }
      footer a { color: rgba(255,255,255,0.4); text-decoration: none; font-size: 0.8rem; }
      footer a:hover { color: var(--red); }

      /* WA FLOAT */
      .wa-float { position: fixed; bottom: 28px; right: 28px; z-index: 999; background: #25d366; width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; box-shadow: 0 6px 25px rgba(37,211,102,0.5); animation: pulse-wa 2.5s infinite; }
      @keyframes pulse-wa { 0%,100%{box-shadow:0 6px 25px rgba(37,211,102,.5);}50%{box-shadow:0 6px 35px rgba(37,211,102,.8),0 0 0 12px rgba(37,211,102,.12);} }
      .wa-float svg { width: 28px; height: 28px; }

      @media (max-width: 700px) {
        nav#mainNav { padding: 0 20px; }
        .breadcrumb, .page-hero, .faq-section { padding-left: 20px; padding-right: 20px; }
        .areas-section, .cta-section { padding: 40px 20px; }
        footer { padding: 24px 20px; flex-direction: column; text-align: center; }
      }
    </style>
  </head>

  <body>

    <!-- WhatsApp flotante -->
    <WhatsAppWidget phoneHref={PHONE_HREF} text={`Hola Marilyn, me interesa el servicio de ${service.name} en ${city.name}.`} />

    <!-- NAVBAR -->
    <nav id="mainNav">
      <div class="nav-logo">M<span>A</span>PA</div>
      <ul class="nav-links" id="navLinks">
        <li><a href="/#hero" data-i18n="nav.home">Inicio</a></li>
        <li><a href="/#servicios" data-i18n="nav.services">Servicios</a></li>
        <li><a href="/#nosotros" data-i18n="nav.about">Nosotros</a></li>
        <li><a href="/#proceso" data-i18n="nav.process">Proceso</a></li>
        <li><a href="/#testimonios" data-i18n="nav.testimonials">Testimonios</a></li>
        <li><a href="/#ubicacion" data-i18n="nav.location">Ubicación</a></li>
        <li><a href="/#contacto" data-i18n="nav.contact">Contacto</a></li>
        <li><a href="/#areas-de-servicio" data-i18n="nav.coverage">Áreas de Servicio</a></li>
        <li><a href={`tel:${PHONE_HREF}`} class="nav-cta" data-i18n="nav.cta">📞 Cita</a></li>
        <li class="lang-selector-li">
          <div class="lang-selector">
            <button class="lang-btn active" data-lang="es" onclick="window.i18n.changeLanguage('es')" aria-label="Cambiar a Español" aria-pressed="true">ES</button>
            <span class="lang-divider">|</span>
            <button class="lang-btn" data-lang="en" onclick="window.i18n.changeLanguage('en')" aria-label="Switch to English" aria-pressed="false">EN</button>
          </div>
        </li>
      </ul>
      <div class="hamburger" id="hamburger" onclick="toggleMenu()">
        <span></span><span></span><span></span>
      </div>
    </nav>

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Ruta de navegación">
      <a href="/" data-i18n="nav.home">Inicio</a>
      <span>›</span>
      <a href={`/service-areas/${city.slug}/`}>{city.name}</a>
      <span>›</span>
      <span data-i18n={`services.${service.slug}.title`}>{service.name}</span>
    </nav>

    <!-- Hero -->
    <div class="page-hero">
      <div class="page-tag" data-i18n="hero.tag_business">MAPA Business & Financial Services LLC</div>
      <div class="page-icon">{service.icon}</div>
      <h1 data-i18n-html={`services.${service.slug}.spoke_title`} set:html={service.h1(city.name).replace(city.name, `<span style="color:#cc0000">${city.name}</span>`)} />
      <p class="page-intro">
        <span data-i18n={`services.${service.slug}.desc`}>{service.intro(city.name)}</span>
        <span data-i18n={`cities.${city.slug}.desc`}>{city.localCommunityDescription}</span>
      </p>
      <div class="hub-link-wrapper">
        <a href={`/servicios/${service.slug}/`} class="hub-link">
          ← <span data-i18n="services.view_general_co">Ver cobertura general de</span> <span data-i18n={`services.${service.slug}.title`}>{service.name}</span> <span data-i18n="services.in_nj">en New Jersey</span>
        </a>
      </div>
      <div class="btn-group">
        <a href={`tel:${PHONE_HREF}`} class="btn btn-red"><span data-i18n="contact.btn_call">📞 Llamar:</span> {PHONE}</a>
        <a href={`https://wa.me/${PHONE_HREF}?text=Hola%20Marilyn%2C%20necesito%20${encodeURIComponent(service.name)}%20en%20${encodeURIComponent(city.name)}.`} target="_blank" class="btn btn-wa" data-i18n="hero.btn_whatsapp">💬 WhatsApp</a>
      </div>
    </div>

    <!-- Áreas de servicio -->
    <div class="areas-section">
      <div class="areas-inner">
        <h2 class="section-label">
          <span data-i18n="services.service_of">Servicio de</span> <span data-i18n={`services.${service.slug}.title`}>{service.name}</span> <span data-i18n="services.in_city">en</span> <span>{city.name}</span> <span data-i18n="services.and_surroundings">y alrededores</span>
        </h2>
        <p style="color:rgba(255,255,255,0.55);font-size:0.9rem;line-height:1.7;">
          <span data-i18n="services.we_serve">Atendemos</span> {city.name} ({city.zipCodes.join(", ")}) <span data-i18n="services.and_following_areas">y las siguientes áreas de</span> {city.county}:
        </p>
        <div class="areas-grid">
          <span class="area-pill">📍 {city.name}, NJ</span>
          {city.nearbyAreas.map((area) => (
            <span class="area-pill">📍 {area}, NJ</span>
          ))}
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <section class="faq-section">
      <h2><span data-i18n="services.faq_title_prefix">Preguntas frecuentes sobre</span> <span data-i18n={`services.${service.slug}.title`}>{service.name}</span> <span data-i18n="services.in_city">en</span> {city.name}</h2>
      <dl>
        {service.faqs.map((faq, idx) => (
          <div class="faq-item">
            <dt data-i18n={`services.${service.slug}.faqs.${idx}.q`}>{faq.question.replace("{city}", city.name)}</dt>
            <dd data-i18n={`services.${service.slug}.faqs.${idx}.a`}>{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- CTA final -->
    <div class="cta-section">
      <h2 data-i18n="services.cta_ready">¿Listo para empezar?</h2>
      <p data-i18n="city.cta_desc">Contáctanos hoy — primera consulta sin costo. Atendemos en español.</p>
      <a href={`tel:${PHONE_HREF}`} class="btn-white">📞 {PHONE}</a>
    </div>

    <!-- Footer -->
    <footer>
      <div class="footer-logo">M<span>A</span>PA</div>
      <p>© {new Date().getFullYear()} <span data-i18n="footer.desc">MAPA Business & Financial Services LLC</span> · Newark, NJ</p>
      <a href="/" data-i18n="city.back_home">← Volver al inicio</a>
    </footer>

    <script define:vars={{ cityName: city.name }}>
      window.currentCity = cityName;
    </script>

    <script src="/js/script.js" is:inline></script>
  </body>
</html>
